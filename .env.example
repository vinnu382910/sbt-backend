PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=replace_with_a_long_random_secret
NODE_ENV=production

# Frontend origins allowed by CORS.
# Keep true while testing Render/Vercel preview URLs. Set false later to enforce the allow-list below.
CORS_ALLOW_ANY_ORIGIN=true
# Local development is allowed automatically when NODE_ENV is not production.
FRONTEND_URL=https://your-vercel-app.vercel.app
FRONTEND_URLS=https://your-vercel-app.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://your-custom-domain.com

# SMTP configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_APP_NAME=sbtexam

# Cloudinary image uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=micro-certification/questions
